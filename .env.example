RELAY_HOST=your.domain.com
DOMAIN=your.domain.com

# Public URL the RustDesk client uses to reach the API.
# Domain + SSL (via Nginx Proxy Manager):  API_PUBLIC_URL=https://your.domain.com
# IP address / no SSL:                     API_PUBLIC_URL=http://1.2.3.4:21114
API_PUBLIC_URL=https://your.domain.com

JWT_SECRET=change_this_to_a_very_long_random_string_before_deploying
APP_SECRET=change_this_dashboard_secret_before_deploying

ADMIN_USER=youradminname
ADMIN_PASS=changeme123

DB_PATH=/data/skonadesk.db
PORT=21114

# Dashboard port on the host (default 8080; use 80 for direct LAN access without a reverse proxy)
DASHBOARD_PORT=8080
